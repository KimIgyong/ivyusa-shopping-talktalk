# Backend (apps/api) — development. Committed per Amoeba Structure v2 (dev only).
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# MySQL (utf8mb4 / InnoDB) — matches chat-widget-schema.sql
DB_HOST=127.0.0.1
DB_PORT=3316
DB_USER=ivy
DB_PASSWORD=ivy_dev_pw
DB_NAME=db_ivy_talktalk
DB_SYNCHRONIZE=true
DB_LOGGING=false

# Redis (session cache, unread counts — tenant-prefixed keys)
REDIS_HOST=127.0.0.1
REDIS_PORT=6389

# RabbitMQ (async notifications, logging, cjm)
RABBITMQ_URL=amqp://ivy:ivy_dev_pw@127.0.0.1:5682

# JWT (Access 15m / Refresh 7d — amoeba_basic_SPEC token policy)
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# AES-256-GCM key for credential encryption (POL-018). 32 bytes, base64.
CRED_ENC_KEY=ZGV2X29ubHlfMzJfYnl0ZV9rZXlfZm9yX2FlczI1NmdjbQ==

# AI gateway — stub works without keys; set to use real providers
AI_DEFAULT_PROVIDER=stub
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Local file storage for KB uploads (dev)
KB_STORAGE_DIR=./storage/kb

# Data retention / disposal (POL-003) — conversation logs purged after N days.
CONVERSATION_LOG_RETENTION_DAYS=365
