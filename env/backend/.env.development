# Backend (apps/api) — development. Committed per Amoeba Structure v2 (dev only).
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# MySQL (utf8mb4 / InnoDB) — matches chat-widget-schema.sql
DB_HOST=127.0.0.1
DB_PORT=3316
DB_USER=ivy
DB_PASSWORD=ivy_dev_pw
DB_NAME=db_ivy_talktalk
DB_SYNCHRONIZE=true
DB_LOGGING=false

# Redis (session cache, unread counts — tenant-prefixed keys)
REDIS_HOST=127.0.0.1
REDIS_PORT=6389

# RabbitMQ (async notifications, logging, cjm)
RABBITMQ_URL=amqp://ivy:ivy_dev_pw@127.0.0.1:5682

# JWT (Access 15m / Refresh 7d — amoeba_basic_SPEC token policy)
JWT_ACCESS_SECRET=dev_access_secret_change_me_0123456789
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_0123456789
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# AES-256-GCM key for credential encryption (POL-018). 32 bytes, base64.
CRED_ENC_KEY=ZGV2X29ubHlfMzJieXRlX2tleV9mb3JfYWVzMjU2Z2M=

# AI gateway — stub works without keys; set to use real providers
AI_DEFAULT_PROVIDER=stub
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Local file storage for KB uploads (dev)
KB_STORAGE_DIR=./storage/kb

# Data retention / disposal (POL-003) — conversation logs purged after N days.
CONVERSATION_LOG_RETENTION_DAYS=365
# Scheduled purge cadence (hours). Runs messages/conversations/cjm/notifications/
# stale-session disposal past the retention window; 0 disables the scheduler.
RETENTION_PURGE_INTERVAL_HOURS=24

# MySQL connection pool size per API instance (PERF-17). Default 30.
DB_POOL_SIZE=30

# Shopify scheduled auto-sync interval in minutes (0/unset = disabled).
SHOPIFY_SYNC_INTERVAL_MIN=0

# Escalation alerts (PLAN-Scenario-Handoff-Alert). Empty values disable a channel;
# the console alarm modal (DB-backed) always works.
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_FROM=alerts@ivyusa.local
ALERT_EMAIL_TO=

# Shopify public-app OAuth (path B). Empty API key/secret disables the endpoints.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_orders,read_customers
SHOPIFY_APP_URL=http://localhost:3000

# Shared secret for the generic fulfillment webhook (X-Webhook-Secret header).
# Empty is allowed ONLY when NODE_ENV=development; staging/prod fail closed.
FULFILLMENT_WEBHOOK_SECRET=
