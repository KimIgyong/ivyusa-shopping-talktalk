# IVY TalkTalk — PRODUCTION environment template. Amoeba Structure v2 §5.1.
# Copy to docker/production/.env.production and fill in real values.
# The real .env.production is gitignored — NEVER commit secrets.

NODE_ENV=production
PORT=3000
API_PREFIX=api/v1

# --- MySQL ---------------------------------------------------------------
# DB_HOST=mysql matches the compose service name on the internal network.
DB_HOST=mysql
DB_PORT=3306
DB_USER=ivy
DB_PASSWORD=change_me_production_db_pw
DB_NAME=db_ivy_talktalk
# Root password is consumed by the mysql container only.
DB_ROOT_PASSWORD=change_me_production_root_pw
# Production uses migrations, never auto-synchronize.
DB_SYNCHRONIZE=false
DB_LOGGING=false

# --- Redis ---------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# --- RabbitMQ ------------------------------------------------------------
RABBITMQ_USER=ivy
RABBITMQ_PASSWORD=change_me_production_mq_pw
RABBITMQ_URL=amqp://ivy:change_me_production_mq_pw@rabbitmq:5672

# --- JWT (Access 15m / Refresh 7d) ---------------------------------------
JWT_ACCESS_SECRET=change_me_production_access_secret
JWT_REFRESH_SECRET=change_me_production_refresh_secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# --- Credential encryption (AES-256-GCM, 32 bytes base64, POL-018) -------
CRED_ENC_KEY=change_me_base64_32_byte_key

# --- AI gateway ----------------------------------------------------------
AI_DEFAULT_PROVIDER=anthropic
ANTHROPIC_API_KEY=change_me_real_api_key
ANTHROPIC_MODEL=claude-opus-4-8

# --- Retention -----------------------------------------------------------
CONVERSATION_LOG_RETENTION_DAYS=365

# --- Frontend build-time (baked into the web image) ----------------------
VITE_API_BASE_URL=https://ivy-talktalk.example.com/api/v1

# --- Bootstrap (self-seed on boot) ---------------------------------------
# Production: schema comes from init-sql (DB_SYNCHRONIZE=false). SEED_ON_BOOT
# inserts bootstrap accounts/tenant via the ORM. Set a strong SEED_PASSWORD and
# SEED_DEMO_DATA=false. Turn SEED_ON_BOOT off after the first successful boot.
SEED_ON_BOOT=true
SEED_DEMO_DATA=false
SEED_PASSWORD=change_me_strong_bootstrap_pw

# --- Shopify webhook verification ---
# REQUIRED: the API rejects Shopify webhooks (incl. shop/redact) when unset.
SHOPIFY_WEBHOOK_SECRET=change_me_shopify_webhook_secret

# --- Generic fulfillment webhook (X-Webhook-Secret header) ---
# REQUIRED: /webhooks/fulfillment rejects requests without a matching secret.
FULFILLMENT_WEBHOOK_SECRET=change_me_fulfillment_webhook_secret
