# IVY TalkTalk — STAGING environment template. Amoeba Structure v2 §5.1.
# Copy to docker/staging/.env.staging and fill in real values.
# The real .env.staging is gitignored — NEVER commit secrets.

NODE_ENV=staging
PORT=3000
API_PREFIX=api/v1

# --- MySQL ---------------------------------------------------------------
# DB_HOST=mysql matches the compose service name on the internal network.
DB_HOST=mysql
DB_PORT=3306
DB_USER=ivy
DB_PASSWORD=change_me_staging_db_pw
DB_NAME=db_ivy_talktalk
# Root password is consumed by the mysql container only.
DB_ROOT_PASSWORD=change_me_staging_root_pw
# Keep synchronize on for staging schema convenience; turn off to use migrations.
DB_SYNCHRONIZE=true
DB_LOGGING=false

# --- Redis ---------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# --- RabbitMQ ------------------------------------------------------------
RABBITMQ_USER=ivy
RABBITMQ_PASSWORD=change_me_staging_mq_pw
RABBITMQ_URL=amqp://ivy:change_me_staging_mq_pw@rabbitmq:5672

# --- CORS (SEC-L1) --------------------------------------------------------
# Comma-separated browser origins allowed to call the API cross-origin.
# Leave unset when web/widget/api are served same-origin behind the edge proxy
# (the default compose topology) - no CORS headers are then emitted.
# CORS_ORIGINS=https://admin.example.com,https://widget.example.com

# --- JWT (Access 15m / Refresh 7d) ---------------------------------------
JWT_ACCESS_SECRET=change_me_staging_access_secret
JWT_REFRESH_SECRET=change_me_staging_refresh_secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# --- Credential encryption (AES-256-GCM, 32 bytes base64, POL-018) -------
CRED_ENC_KEY=change_me_base64_32_byte_key

# --- AI gateway ----------------------------------------------------------
AI_DEFAULT_PROVIDER=stub
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Retention -----------------------------------------------------------
CONVERSATION_LOG_RETENTION_DAYS=90
# Scheduled purge cadence (hours). Runs messages/conversations/cjm/notifications/
# stale-session disposal past the retention window; 0 disables the scheduler.
RETENTION_PURGE_INTERVAL_HOURS=24

# MySQL connection pool size per API instance (PERF-17). Default 30.
DB_POOL_SIZE=30

# --- Bootstrap (self-seed on boot; no ts-node in the image) --------------
# SEED_ON_BOOT runs the idempotent bootstrap seed at API startup (tenant ivyusa,
# admin@/dev@ accounts — must change password on first login).
SEED_ON_BOOT=true
SEED_DEMO_DATA=true            # set false for a clean staging without demo orders
# SEED_PASSWORD=                # override the default bootstrap password (recommended)

# --- Shopify webhook verification (GDPR compliance webhooks) -------------
# REQUIRED outside dev: the API rejects Shopify webhooks (incl. shop/redact) when unset.
SHOPIFY_WEBHOOK_SECRET=

# --- Generic fulfillment webhook (X-Webhook-Secret header) ---------------
# REQUIRED outside dev: /webhooks/fulfillment rejects requests without a match.
FULFILLMENT_WEBHOOK_SECRET=

# --- Frontend build-time (baked into the web image) ----------------------
VITE_API_BASE_URL=https://staging.ivy-talktalk.example.com/api/v1
