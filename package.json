{
  "name": "ivy-talktalk",
  "version": "1.0.0",
  "private": true,
  "description": "IVY USA Chat & Customer Support Widget — Shopify storefront (Naver TalkTalk style)",
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:up": "docker compose -f docker/docker-compose.dev.yml up -d",
    "db:down": "docker compose -f docker/docker-compose.dev.yml down",
    "db:seed": "npm run seed --workspace=@ivy/api"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "prettier": "^3.2.0",
    "eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
